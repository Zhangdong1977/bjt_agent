# ============================================================
# Node 3 配置: API + Review×3（无 Parser）
# CPU 8C / 内存 16GB
# ============================================================

NODE_ROLE=api-review-only

BACKEND_PORT=8001
BACKEND_WORKERS=4

# Celery Review Worker（3 个实例，各 concurrency=3）
REVIEW_WORKER_COUNT=3
REVIEW_CONCURRENCY=3
REVIEW_MAX_TASKS_PER_CHILD=5
REVIEW_MAX_MEMORY_PER_CHILD=2500000

# 无 Parser Worker
PARSER_WORKER_COUNT=0
PARSER_CONCURRENCY=2
PARSER_MAX_MEMORY_PER_CHILD=2000000

START_RAG_MEMORY=false

MAX_SUB_AGENT_CONCURRENCY=3
