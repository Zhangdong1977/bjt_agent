# ============================================================
# Node 1 配置: API + Review×2 + Parser×1
# CPU 8C / 内存 12GB
# ============================================================

# 节点角色（由 bjt-cluster.sh 读取）
NODE_ROLE=api-review-parser

# API 服务
BACKEND_PORT=8001
BACKEND_WORKERS=4

# Celery Review Worker（2 个实例，各 concurrency=3）
REVIEW_WORKER_COUNT=2
REVIEW_CONCURRENCY=3
REVIEW_MAX_TASKS_PER_CHILD=5
REVIEW_MAX_MEMORY_PER_CHILD=2500000

# Celery Parser Worker（1 个实例，concurrency=2）
PARSER_WORKER_COUNT=1
PARSER_CONCURRENCY=2
PARSER_MAX_MEMORY_PER_CHILD=2000000

# RAG Memory Service
START_RAG_MEMORY=false

# 子 Agent 并行数
MAX_SUB_AGENT_CONCURRENCY=3
