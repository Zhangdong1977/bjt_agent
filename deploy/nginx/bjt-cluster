# ============================================================
# BJT Agent - 集群模式 Nginx 配置
# 部署于独立 LB 节点或每台 API 节点（任选）
#
# 使用方式：
#   sudo cp bjt-cluster /etc/nginx/sites-available/bjt-cluster
#   sudo ln -s /etc/nginx/sites-available/bjt-cluster /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# 注意：将 node1/node2/node3 替换为实际 IP 或主机名
# ============================================================

# SSE 连接数上限（单个 worker），集群 3 节点 × 默认 512 = 1536
# 放在 http 块或 /etc/nginx/nginx.conf 中：
# worker_connections 2048;

upstream bjt_backend {
    # ip_hash: SSE 长连接会话粘滞，同一客户端请求始终路由到同一后端
    ip_hash;

    # --- 按实际 IP 修改 ---
    server node1:8001 max_fails=3 fail_timeout=30s;
    server node2:8001 max_fails=3 fail_timeout=30s;
    server node3:8001 max_fails=3 fail_timeout=30s;
    # -----------------------

    # 备用：当所有节点都 down 时返回 502
    # 保持连接长连接，减少 TCP 握手开销
    keepalive 32;
}

server {
    # ⚠️ 不要启用 http2：HTTP/2 下 Chrome/Edge 的 xhr.upload.onprogress 触发不可靠，
    # 会导致大文件上传进度条卡 0% 跳 100%。HTTP/1.1 下 XHR 上传进度在所有浏览器都可靠。
    listen 8000 ssl;
    server_name _;

    root /home/bjt/bjt_agent/frontend/dist;
    index index.html;

    client_max_body_size 500M;

    # ---- Backend API + SSE 反向代理 ----
    location ^~ /health {
        proxy_pass http://bjt_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 健康检查短超时
        proxy_connect_timeout 5s;
        proxy_read_timeout 10s;
    }

    # ---- 上传接口：限并发（每 IP 同时上传 ≤3，防多用户/多标签页打满带宽）----
    # 用正则精确匹配上传端点并对每 IP 限连接数。注意 nginx location 优先级：
    # ^~ 前缀匹配命中后不再查正则，故下方 /api 已降级为普通前缀（location /api），
    # 本正则 location 才能优先生效。GET 列表（同路径 projects/{id}/documents）
    # 虽也命中，但瞬时完成、不占长连接，不会误伤。
    #
    # ⚠️ limit_conn_zone 必须定义在 http{} 块，请在 /etc/nginx/nginx.conf 的 http{} 内加：
    #       limit_conn_zone $binary_remote_addr zone=upload_conn:1m;
    location ~ ^/api/(projects/[^/]+/documents|documents/upload|knowledge/upload)$ {
        limit_conn upload_conn 3;     # 每 IP 同时上传 ≤3
        limit_conn_status 429;        # 超限返回 429（前端已有全局 429 处理）

        proxy_pass http://bjt_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 请求体流式：前端上传进度条可靠 + 配合后端 throttled_save 端到端限速
        proxy_request_buffering off;
        # 慢速上传（4MB/s × 500MB ≈ 125s）耗时变长，放宽读写超时
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /api {
        proxy_pass http://bjt_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSE 关键配置
        proxy_buffering off;
        proxy_cache off;

        # 大文件上传：关闭请求体缓冲，让字节流直通后端，
        # 否则前端 xhr.upload.onprogress 会卡 0% 跳 100%
        proxy_request_buffering off;

        # SSE 长连接：审查任务最长 8 小时 + 余量
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
        proxy_connect_timeout 60s;

        # 禁用 Nginx 缓冲，确保 SSE 事件实时推送
        # (后端也会发送 X-Accel-Buffering: no，双重保障)
        chunked_transfer_encoding on;

        # HTTP/1.1 长连接（upstream keepalive 需要）
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }

    # ---- 前端路由 ----
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ---- 静态资源缓存 ----
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
