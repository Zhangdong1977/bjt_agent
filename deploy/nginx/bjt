# Frontend + Backend API (端口 8000)
# 单机部署模板：upstream 指 127.0.0.1:8001。集群部署见 bjt-cluster。
# 生产实际配置 /etc/nginx/sites-available/bjt 已切集群 upstream（192.168.40.110/111/112）
# + SSL 证书（check.aibjt.com_bundle.pem）+ client_max_body_size 300M。
server {
    listen 8000 ssl http2;
    server_name _;

    root /home/bjt/bjt_agent/frontend/dist;
    index index.html;

    client_max_body_size 500M;

    # Backend 健康检查和 API 反向代理 (优先匹配)
    location ^~ /health {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400;
    }

    location ^~ /api {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 响应流式：SSE 实时推送解析进度
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400;

        # 请求体流式：关闭缓冲，让大文件上传字节流直通后端，
        # 否则 nginx 先缓存整个请求体到磁盘，前端 xhr.upload.onprogress 会卡 0% 跳 100%
        proxy_request_buffering off;
    }

    # 前端路由支持
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}