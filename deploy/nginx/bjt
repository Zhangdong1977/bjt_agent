# Frontend + Backend API (端口 8000)
# 单机部署模板：upstream 指 127.0.0.1:8001。集群部署见 bjt-cluster。
# 生产实际配置 /etc/nginx/sites-available/bjt 已切集群 upstream（192.168.40.110/111/112）
# + SSL 证书（check.aibjt.com_bundle.pem）+ client_max_body_size 300M。
#
# ⚠️ 不要启用 http2：HTTP/2 下 Chrome/Edge 的 xhr.upload.onprogress 触发不可靠，
# 会导致大文件上传进度条卡 0% 跳 100%。HTTP/1.1 下 XHR 上传进度在所有浏览器都可靠。
# 想保留 HTTP/2 又要平滑进度，需后端实现 /upload/progress 端点（详见 docs）。
server {
    listen 8000 ssl;
    server_name _;

    root /home/bjt/bjt_agent/frontend/dist;
    index index.html;

    client_max_body_size 500M;

    # Backend 健康检查和 API 反向代理 (优先匹配)
    location ^~ /health {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400;
    }

    # ---- 上传接口：限并发（每 IP 同时上传 ≤3，防多用户/多标签页打满带宽）----
    # 用正则精确匹配上传端点并对每 IP 限连接数。注意 nginx location 优先级：
    # ^~ 前缀匹配命中后不再查正则，故下方 /api 已降级为普通前缀（location /api），
    # 本正则 location 才能优先生效。GET 列表（同路径 projects/{id}/documents）
    # 虽也命中，但瞬时完成、不占长连接，不会误伤。
    #
    # ⚠️ limit_conn_zone 必须定义在 http{} 块，请在 /etc/nginx/nginx.conf 的 http{} 内加：
    #       limit_conn_zone $binary_remote_addr zone=upload_conn:1m;
    location ~ ^/api/(projects/[^/]+/documents|documents/upload|knowledge/upload)$ {
        limit_conn upload_conn 3;     # 每 IP 同时上传 ≤3
        limit_conn_status 429;        # 超限返回 429（前端已有全局 429 处理）

        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 请求体流式：前端上传进度条可靠 + 配合后端 throttled_save 端到端限速
        proxy_request_buffering off;
        # 慢速上传（4MB/s × 500MB ≈ 125s）耗时变长，放宽读写超时
        proxy_read_timeout 600s;
        proxy_send_timeout 600s;
    }

    location /api {
        proxy_pass http://127.0.0.1:8001;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 响应流式：SSE 实时推送解析进度
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400;

        # 请求体流式：关闭缓冲，让大文件上传字节流直通后端，
        # 否则 nginx 先缓存整个请求体到磁盘，前端 xhr.upload.onprogress 会卡 0% 跳 100%
        proxy_request_buffering off;
    }

    # 前端路由支持
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}