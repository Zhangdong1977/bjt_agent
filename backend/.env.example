# Environment variables for backend

# Application
APP_NAME="Bid Review Agent"
DEBUG=false

# Security
SECRET_KEY="your-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL="postgresql+asyncpg://user:password@host:port/database"

# Redis
REDIS_URL="redis://host:port/0"

# Operate platform integration. Pre-release/dev usually uses direct backend URL
# without /prod-api; production uses the nginx URL with /prod-api.
OPERATE_API_BASE_URL="http://127.0.0.1:40000"
OPERATE_INTERNAL_TOKEN=""

# 充值套餐可见性 / 真实交行支付。生产环境务必按下表配置，否则会暴露 1 分钱「测试套餐」。
#   dev:  BILLING_REAL_PAY_ENABLED=true, BILLING_REAL_PACKAGE_CODES="test",
#         BILLING_TEST_PACKAGE_ENABLED=true（显式开启测试套餐）
#   prod: BILLING_REAL_PAY_ENABLED=true,
#         BILLING_REAL_PACKAGE_CODES="experience,basic,premium,luxury",
#         BILLING_HIDDEN_PACKAGE_CODES="test"（双保险，配合 BILLING_TEST_PACKAGE_ENABLED 默认 false）
BILLING_REAL_PAY_ENABLED=false
BILLING_REAL_PACKAGE_CODES=""
BILLING_HIDDEN_PACKAGE_CODES=""
# 测试套餐开关：默认 false（fail-closed）。prod 切勿设为 true；dev 设 true 才能在充值页看到 1 分钱测试套餐。
BILLING_TEST_PACKAGE_ENABLED=false

# RAG Memory Service
RAG_MEMORY_SERVICE_URL="http://localhost:3001"

# OCR Service (leave empty for local RapidOCR mode)
OCR_SERVICE_URL=""

# 图像理解引擎切换：minimax（默认，MiniMax MCP VLM）/ baidu（百度云 OCR）/ volcengine
IMAGE_UNDERSTANDING_PROVIDER="minimax"

# 百度云 OCR（通用文字识别-高精度版 accurate_basic），IMAGE_UNDERSTANDING_PROVIDER=baidu 时必填
BAIDU_OCR_APP_ID="your-baidu-app-id"
BAIDU_OCR_API_KEY="your-baidu-api-key"
BAIDU_OCR_SECRET_KEY="your-baidu-secret-key"

# Mini-Agent API
MINI_AGENT_API_KEY="your-minimax-api-key"
MINI_AGENT_API_BASE="https://api.minimaxi.com"
MINI_AGENT_MODEL="MiniMax-M2.7-highspeed"

# LLM Provider: "minimax" (default), "volcengine", or "deepseek"
LLM_PROVIDER="minimax"

# Volcengine / 火山引擎
VOLCENGINE_API_KEY="your-volcengine-api-key"
VOLCENGINE_API_BASE="https://ark.cn-beijing.volces.com/api/v3"
VOLCENGINE_MODEL="doubao-seed-2-0-pro-260215"

# DeepSeek
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_BASE="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-v4-flash"

# Workspace
WORKSPACE_DIR="./workspace"

# Rule Library
RULE_LIBRARY_DIR="./docs/rules"

# Proxy
HTTP_PROXY="http://127.0.0.1:7890"
HTTPS_PROXY="http://127.0.0.1:7890"

# Sub-Agent Concurrency
MAX_SUB_AGENT_CONCURRENCY=2
MAX_LLM_CONCURRENCY=0
