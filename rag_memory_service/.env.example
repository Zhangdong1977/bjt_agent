# rag-memory Service Configuration
# rag-memory 服务配置

# =====================================================================
# 必需配置 Required Configuration
# =====================================================================

# ZhipuAI API Key (required)
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your_zhipu_api_key_here

# =====================================================================
# 服务器配置 Server Configuration
# =====================================================================

# Service Port (default: 3001)
# 服务监听端口
PORT=3001

# Service Host (default: 0.0.0.0)
# 服务监听地址
HOST=0.0.0.0

# =====================================================================
# 路径配置 Path Configuration
# =====================================================================

# Documents Path (default: ./knowledge_docs)
# Markdown 文档存储目录
DOCUMENTS_PATH=./knowledge_docs

# Index Database Path (default: ./data/memory.sqlite)
# SQLite 索引文件存储路径
INDEX_PATH=./data/memory.sqlite

# =====================================================================
# 模型配置 Model Configuration
# =====================================================================

# Embedding Model (default: embedding-3)
# 嵌入模型名称
EMBEDDING_MODEL=embedding-3

# =====================================================================
# 服务配置 Service Configuration
# =====================================================================

# Log Level: debug, info, warn, error (default: info)
# 日志级别
LOG_LEVEL=info

# Max Search Results (default: 50, max: 100)
# 最大搜索结果数
MAX_SEARCH_RESULTS=50

# Search Timeout in milliseconds (default: 5000)
# 搜索超时时间（毫秒）
SEARCH_TIMEOUT=5000

# =====================================================================
# 搜索配置 Search Configuration
# =====================================================================

# Vector Search Weight (default: 0.7, range: 0-1)
# 向量搜索权重（语义检索）
VECTOR_WEIGHT=0.7

# BM25 Search Weight (default: 0.3, range: 0-1)
# BM25 搜索权重（关键词检索）
BM25_WEIGHT=0.3

# Note: VECTOR_WEIGHT + BM25_WEIGHT should equal 1.0

# =====================================================================
# 缓存配置 Cache Configuration
# =====================================================================

# Enable Cache (default: true)
# 启用缓存
ENABLE_CACHE=true

# Cache TTL in seconds (default: 300, max: 3600)
# 缓存过期时间（秒）
CACHE_TTL=300

# =====================================================================
# 健康检查配置 Health Check Configuration
# =====================================================================

# Health Check Interval in seconds (default: 30)
# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# Health Check Timeout in seconds (default: 10)
# 健康检查超时（秒）
HEALTH_CHECK_TIMEOUT=10
