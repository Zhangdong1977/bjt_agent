From c945f9a1096149639d228b2ac0443d9ba838b7a5 Mon Sep 17 00:00:00 2001
From: ZhangDong <yabooo@163.com>
Date: Thu, 16 Apr 2026 09:35:32 +0800
Subject: [PATCH] feat: add timeout and max_tokens support to LLM clients

- Add timeout parameter to AnthropicClient and OpenAIClient
- Add max_tokens parameter to generate methods
- Fix Celery LoggingProxy STDIO transport issue

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 mini_agent/llm/anthropic_client.py | 11 ++++++++++-
 mini_agent/llm/base.py             |  2 ++
 mini_agent/llm/llm_wrapper.py      |  9 ++++++++-
 mini_agent/llm/openai_client.py    | 12 ++++++++++++
 mini_agent/tools/mcp_loader.py     | 29 +++++++++++++++++++++++++++--
 5 files changed, 59 insertions(+), 4 deletions(-)

diff --git a/mini_agent/llm/anthropic_client.py b/mini_agent/llm/anthropic_client.py
index 6baf994..5b256cc 100644
--- a/mini_agent/llm/anthropic_client.py
