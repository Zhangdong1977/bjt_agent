    "hybrid-search",
    "typescript"
  ],
  "author": "OpenClaw contributors",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.5.3",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.0.0",
    "openai": "^4.0.0",
    "@google/generative-ai": "^0.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/rag-memory"
