{
  "name": "rag-memory",
  "version": "1.0.0",
  "description": "Hybrid RAG memory system with vector + keyword search for TypeScript/Node.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "example:basic": "tsx examples/basic.ts",
    "example:knowledge": "tsx examples/knowledge-base.ts"
  },
  "keywords": [
